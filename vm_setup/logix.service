[Unit]
Description=Logix Backend (FastAPI with Granian)
After=network.target

[Service]
# IMPORTANTE: Cambia 'tu_usuario' por el usuario linux real (ej. 'ubuntu', 'root', 'fabio')
User=debian
Group=www-data
WorkingDirectory=/home/debian/logix

# Cargar variables de entorno desde archivo .env
EnvironmentFile=/home/debian/logix/.env

# Variables extra si son necesarias (PATH suele requerirse explícitamente)
Environment="PATH=/home/debian/logix/venv/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/home/debian/logix/venv/bin/granian --interface asgi main:app --host 127.0.0.1 --port 8000 --workers 2

[Install]
WantedBy=multi-user.target
